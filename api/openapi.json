    "/api/websites/{websiteID}/metrics": {
      "get": {
        "operationId": "websiteMetrics",
        "parameters": [
          {
            "in": "path",
            "name": "websiteID",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "explode": false,
            "in": "query",
            "name": "startAt",
            "schema": {
              "format": "int64",
              "type": "integer"
            }
          },
          {
            "explode": false,
            "in": "query",
            "name": "endAt",
            "schema": {
              "format": "int64",
              "type": "integer"
            }
          },
          {
            "explode": false,
            "in": "query",
            "name": "type",
            "required": true,
            "schema": {
              "enum": [
                "path",
                "referrer",
                "browser",
                "os",
                "device",
                "country",
                "event"
              ],
              "type": "string"
            }
          },
          {
            "explode": false,
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 10,
              "maximum": 100,
              "minimum": 1,
              "type": "integer"
            }
          }
