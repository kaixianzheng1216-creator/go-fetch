                "schema": {
                  "$ref": "#/components/schemas/ErrorModel"
                }
              }
            },
            "description": "Error"
          }
        },
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "summary": "Get website stats",
        "tags": [
          "Analytics"
        ]
      }
    }
  },
  "servers": [
