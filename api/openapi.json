        "summary": "Get current user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/websites": {
      "get": {
        "operationId": "listWebsites",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/WebsiteResponse"
                  },
                  "type": [
